{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@api/*":  ["./api/src/*"],
      "@cli/*":  ["./cli/src/*"]
    }
  },
  "include": ["api/src/**/*", "cli/src/**/*", "build.mjs"]
}
